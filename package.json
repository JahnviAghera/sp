{
  "name": "speakspace-backend",
  "version": "0.1.0",
  "description": "SpeakSpace backend: real-time GD & interview skill builder",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "frontend": "cd frontend && npm run dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend\"",
    "test": "jest --config jest.config.json --testPathPattern=tests/",
    "test:watch": "jest --config jest.config.json --testPathPattern=tests/ --watch",
    "test:coverage": "jest --config jest.config.json --testPathPattern=tests/ --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "nanoid": "^3.3.12",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2"
  }
}
